# Archimedes Backend — Environment Variables
# Copy to .env and fill in values after deploying contracts.

# ─── Arc RPC ──────────────────────────────────────────────────
ARC_ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=13068200

# ─── Agent Account (calls rebalance, publishes traces) ────────
ARC_AGENT_PRIVATE_KEY=0x...
ARC_OWNER_PRIVATE_KEY=0x...

# ─── Contract Addresses (from Deploy.s.sol output) ───────────
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_AMM_ROUTER_ADDRESS=
ARC_SYNTHETIC_FACTORY_ADDRESS=
ARC_VAULT_FACTORY_ADDRESS=
ARC_REASONING_TRACE_REGISTRY_ADDRESS=
ARC_ASSET_REGISTRY_ADDRESS=

# ─── Synthetic Token Addresses ───────────────────────────────
ARC_STSLA_ADDRESS=
ARC_SNVDA_ADDRESS=
ARC_SSPY_ADDRESS=
ARC_SBTC_ADDRESS=
ARC_SGOLD_ADDRESS=

# ─── Oracle Addresses ────────────────────────────────────────
ARC_STSLA_ORACLE_ADDRESS=
ARC_SNVDA_ORACLE_ADDRESS=
ARC_SSPY_ORACLE_ADDRESS=
ARC_SBTC_ORACLE_ADDRESS=
ARC_SGOLD_ORACLE_ADDRESS=

# --- x402 / Circle Gateway (D1) ---
# Address that receives batched USDC settlement from Circle Gateway.
# DECISION-GATED: PaymentSplitter address vs platform treasury. Placeholder for now.
GATEWAY_SELLER_ADDRESS=0x0000000000000000000000000000000000000000
# circlekit chain name (see circlekit.constants). arcTestnet for dev/test.
GATEWAY_CHAIN=arcTestnet
